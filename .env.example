# agentic-iam/.env.example
# Copy this to .env and fill in your real values. Never commit .env.

# Azure AD / Entra ID
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-service-principal-client-id
AZURE_CLIENT_SECRET=your-service-principal-client-secret

# Microsoft Graph (leave as-is for local dev)
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# Cosmos DB (leave blank locally — audit logs go to audit.jsonl instead)
COSMOS_DB_ENDPOINT=
COSMOS_DB_KEY=
COSMOS_DATABASE=iam-db

# OpenAI (use openai.com directly for local dev)
OPENAI_ENDPOINT=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Service Bus (leave blank locally — not needed yet)
SERVICE_BUS_CONN=

# Runtime
ENVIRONMENT=dev
BOT_TYPE=user_bot